		isHidden
		lineageTag: 40c55cd1-c126-4fcb-8c60-4932826b5e8c
		summarizeBy: none
		sourceColumn: Quarter No

		annotation SummarizationSetBy = Automatic

	column 'Month Number'
		dataType: int64
		isHidden
		lineageTag: 89a0f462-87f9-4480-838a-0bd0bf4dfcf2
		summarizeBy: none
		sourceColumn: Month Number

