table Date
	lineageTag: 609eb77e-c031-48e2-8186-4f83f71f2bc5
	dataCategory: Time

	column Date
		dataType: dateTime
		isKey
		formatString: dd mmm yyyy
		lineageTag: efa0c858-c11b-4fbf-ac6b-7fc575d0d645
		summarizeBy: none
		sourceColumn: Date

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

