{
  "name": "Datapot",
  "dataColors": [
    "#1F6FEB",
    "#11A8CD",
    "#16B98B",
    "#F5A524",
    "#E5484D",
    "#8B5CF6",
    "#0A3D91",
    "#6E7681",
    "#3FB950",
    "#D29922"
  ],
  "background": "#FFFFFF",
  "foreground": "#1F2933",
  "foregroundNeutralSecondary": "#52606D",
  "tableAccent": "#1F6FEB",
  "good": "#16B98B",
  "neutral": "#F5A524",
  "bad": "#E5484D",
  "maximum": "#0A3D91",
  "center": "#F5A524",
  "minimum": "#E5484D",
  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 14,
      "color": "#1F2933"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 12,
      "color": "#1F2933"
    },
    "callout": {
      "fontFace": "Segoe UI",
      "fontSize": 32,
      "color": "#0A3D91"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#52606D"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#1F2933"
              }
            },
            "fontSize": 12,
            "alignment": "left"
          }
        ],
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#E4E7EB"
              }
            },
            "radius": 6
          }
        ],
        "dropShadow": [
          {
            "show": false
          }
        ]
      }
    },
    "textbox": {
      "*": {
        "title": [
          {
            "show": false
          }
        ],
        "background": [
          {
            "show": false
          }
        ],
        "border": [
          {
            "show": false
          }
        ],
        "dropShadow": [
          {
            "show": false
          }
        ]
      }
    }
  }
